{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "projectprestisius",
  "compatibility_date": "2026-07-01",

  "assets": {
    "directory": "./dist/client",
  },

  // Variabel lingkungan untuk aplikasi Astro
  "vars": {
    "PUBLIC_R2_URL": "https://cdn.trimit.my.id",
  },

  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "trimit-assets",
    },
  ],
}
