---
interface Props {
  title: string;
  description: string;
}

const {
  title,
  description,
} = Astro.props;
---

<div class="rounded-2xl border border-dashed border-zinc-300 bg-white px-6 py-16 text-center">

  <h3 class="text-lg font-semibold">
    {title}
  </h3>

  <p class="mt-2 text-sm text-zinc-500">
    {description}
  </p>

</div>