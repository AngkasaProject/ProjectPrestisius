---
import {
  Home,
  Shield,
  FileText,
  Info,
} from "lucide-react";

interface Props {
  current: "home" | "privacy" | "terms" | "disclaimer";
}

const { current } = Astro.props;

const items = [
  {
    key: "home",
    label: "Home",
    href: "/",
    icon: Home,
  },
  {
    key: "privacy",
    label: "Privacy",
    href: "/legal/privacy",
    icon: Shield,
  },
  {
    key: "terms",
    label: "Terms",
    href: "/legal/terms",
    icon: FileText,
  },
  {
    key: "disclaimer",
    label: "Disclaimer",
    href: "/legal/disclaimer",
    icon: Info,
  },
];
---

<div class="fixed inset-x-0 bottom-4 z-50 px-4">

  <div class="mx-auto w-fit max-w-full overflow-x-auto">

    <nav
      class="flex items-center gap-2 rounded-2xl border border-zinc-200/80 bg-white/90 p-2 shadow-xl backdrop-blur-xl"
    >
      {
        items.map((item) => {
          const Icon = item.icon;

          return (
            <a
              href={item.href}
              class:list={[
                "flex h-11 items-center justify-center rounded-xl transition-all duration-200",

                // Mobile
                "w-11",

                // Desktop
                "md:h-auto md:w-auto md:gap-2 md:px-4 md:py-2.5",

                current === item.key
                  ? "bg-lime-500 text-white shadow"
                  : "text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900",
              ]}
            >
              <Icon size={18} />

              <span class="hidden md:inline">
                {item.label}
              </span>
            </a>
          );
        })
      }
    </nav>

  </div>

</div>