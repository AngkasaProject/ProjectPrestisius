---
import {
  Mail,
  Phone,
  Globe,
} from "lucide-react";

const year = new Date().getFullYear();
---

<footer class="relative mt-24 overflow-hidden border-t border-zinc-200 bg-linear-to-b from-zinc-100 via-white to-zinc-100">

  <!-- Top Glow -->
  <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-lime-500/60 to-transparent"></div>

  <!-- Background Glow -->
  <div class="absolute inset-x-0 top-0 h-80 bg-radial-[at_top] from-lime-400/15 via-transparent to-transparent"></div>

  <div class="relative mx-auto max-w-7xl px-6 py-20">

    <div class="grid gap-14 lg:grid-cols-[2.2fr_1fr_1fr_1fr]">

      <!-- Brand -->
      <div>

        <a href="/" class="inline-flex items-center">
          <img
            src="/brand/logo.png"
            alt="TRIMIT"
            class="h-12 w-auto"
          />
        </a>

        <p class="mt-8 max-w-sm leading-8 text-zinc-600">
          Modern Link Management Platform untuk membuat Short Link,
          Bio Link, QR Code, dan Custom Open Graph dalam satu dashboard
          yang cepat, aman, dan mudah digunakan.
        </p>

        <div class="mt-8 space-y-4">

          <a
            href="tel:+628123456789"
            class="flex items-center gap-3 text-zinc-700 transition hover:text-lime-600"
          >
            <Phone size={18} />

            <span>+62 812-3456-7890</span>
          </a>

          <a
            href="mailto:hello@trimit.my.id"
            class="flex items-center gap-3 text-zinc-700 transition hover:text-lime-600"
          >
            <Mail size={18} />

            <span>hello@trimit.my.id</span>
          </a>

        </div>

      </div>

      <!-- Features -->
      <div>

        <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-zinc-900">
          Features
        </h3>

        <nav class="mt-8 space-y-4">

          <a href="#" class="block text-zinc-600 transition hover:text-lime-600">
            Short Links
          </a>

          <a href="#" class="block text-zinc-600 transition hover:text-lime-600">
            Bio Links
          </a>

          <a href="#" class="block text-zinc-600 transition hover:text-lime-600">
            QR Codes
          </a>

          <a href="#" class="block text-zinc-600 transition hover:text-lime-600">
            Custom Open Graph
          </a>

        </nav>

      </div>

      <!-- Legal -->
      <div>

        <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-zinc-900">
          Legal
        </h3>

        <nav class="mt-8 space-y-4">

          <a
            href="/legal/privacy"
            class="block text-zinc-600 transition hover:text-lime-600"
          >
            Privacy Policy
          </a>

          <a
            href="/legal/terms"
            class="block text-zinc-600 transition hover:text-lime-600"
          >
            Terms of Service
          </a>

          <a
            href="/legal/disclaimer"
            class="block text-zinc-600 transition hover:text-lime-600"
          >
            Disclaimer
          </a>

        </nav>

      </div>

      <!-- Contact -->
      <div>

        <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-zinc-900">
          Contact
        </h3>

        <div class="mt-8 flex flex-wrap gap-3">

          <a
            href="mailto:hello@trimit.my.id"
            aria-label="Email"
            class="flex h-14 w-14 items-center justify-center rounded-2xl border border-zinc-200 bg-white text-zinc-700 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-lime-500 hover:bg-lime-500 hover:text-white"
          >
            <Mail size={20} />
          </a>

          <a
            href="tel:+628123456789"
            aria-label="Phone"
            class="flex h-14 w-14 items-center justify-center rounded-2xl border border-zinc-200 bg-white text-zinc-700 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-lime-500 hover:bg-lime-500 hover:text-white"
          >
            <Phone size={20} />
          </a>

          <a
            href="https://trimit.my.id"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Website"
            class="flex h-14 w-14 items-center justify-center rounded-2xl border border-zinc-200 bg-white text-zinc-700 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-lime-500 hover:bg-lime-500 hover:text-white"
          >
            <Globe size={20} />
          </a>

        </div>

      </div>

    </div>

    <div class="mt-16 border-t border-zinc-200 pt-8">

      <div class="flex flex-col gap-5 md:flex-row md:items-center md:justify-between">

      <p class="flex flex-wrap items-center gap-1 text-sm text-zinc-500">
  <span>© {year}</span>

  <span class="font-semibold text-zinc-900">
    TRIMIT
  </span>

  <span>All rights reserved.</span>
</p>


      </div>

    </div>

  </div>

</footer>