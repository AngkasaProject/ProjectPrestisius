---
import {
  Mail,
  Phone,
  Globe,
} from "lucide-react";

const year = new Date().getFullYear();
---

<footer class="relative mt-24 overflow-hidden bg-zinc-950 text-white">

  <!-- Glow -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-lime-400 to-transparent" />

  <div class="absolute inset-x-0 top-0 h-72 bg-radial-[at_top] from-lime-500/10 via-transparent to-transparent"></div>

  <div class="relative mx-auto max-w-7xl px-6 py-20">

    <div class="grid gap-14 lg:grid-cols-[2.2fr_1fr_1fr_1fr]">

      <!-- Brand -->
      <div>

        <a href="/" class="inline-flex items-center gap-4">

          <img
            src="/brand/logo-putih.png"
            alt="TRIMIT"
            class="h-12 w-auto"
          />

        </a>

        <p class="mt-8 max-w-sm leading-8 text-zinc-400">
          Modern Link Management Platform untuk membuat Short Link,
          Bio Link, QR Code, dan Custom Open Graph dalam satu dashboard
          yang cepat, aman, dan mudah digunakan.
        </p>

        <div class="mt-8 space-y-4">

          <a
            href="tel:+628123456789"
            class="flex items-center gap-3 text-zinc-300 transition hover:text-lime-400"
          >
            <Phone size={18} />

            <span>+62 812-3456-7890</span>
          </a>

          <a
            href="mailto:hello@trimit.my.id"
            class="flex items-center gap-3 text-zinc-300 transition hover:text-lime-400"
          >
            <Mail size={18} />

            <span>hello@trimit.my.id</span>
          </a>

        </div>

      </div>

      <!-- Features -->
      <div>

        <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-white">
          Features
        </h3>

        <nav class="mt-8 space-y-4">

          <a href="#" class="block text-zinc-400 transition hover:text-lime-400">
            Short Links
          </a>

          <a href="#" class="block text-zinc-400 transition hover:text-lime-400">
            Bio Links
          </a>

          <a href="#" class="block text-zinc-400 transition hover:text-lime-400">
            QR Codes
          </a>

          <a href="#" class="block text-zinc-400 transition hover:text-lime-400">
            Custom Open Graph
          </a>

        </nav>

      </div>

      <!-- Legal -->
      <div>

        <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-white">
          Legal
        </h3>

        <nav class="mt-8 space-y-4">

          <a
            href="/legal/privacy"
            class="block text-zinc-400 transition hover:text-lime-400"
          >
            Privacy Policy
          </a>

          <a
            href="/legal/terms"
            class="block text-zinc-400 transition hover:text-lime-400"
          >
            Terms of Service
          </a>

          <a
            href="/legal/disclaimer"
            class="block text-zinc-400 transition hover:text-lime-400"
          >
            Disclaimer
          </a>

        </nav>

      </div>

      <!-- Contact -->
      <div>

        <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-white">
          Contact
        </h3>

        <div class="mt-8 flex flex-wrap gap-3">

          <a
            href="mailto:hello@trimit.my.id"
            aria-label="Email"
            class="flex h-14 w-14 items-center justify-center rounded-2xl bg-zinc-900 text-zinc-300 transition-all duration-300 hover:-translate-y-1 hover:bg-lime-500 hover:text-white"
          >
            <Mail size={20} />
          </a>

          <a
            href="tel:+628123456789"
            aria-label="Phone"
            class="flex h-14 w-14 items-center justify-center rounded-2xl bg-zinc-900 text-zinc-300 transition-all duration-300 hover:-translate-y-1 hover:bg-lime-500 hover:text-white"
          >
            <Phone size={20} />
          </a>

          <a
            href="https://trimit.my.id"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Website"
            class="flex h-14 w-14 items-center justify-center rounded-2xl bg-zinc-900 text-zinc-300 transition-all duration-300 hover:-translate-y-1 hover:bg-lime-500 hover:text-white"
          >
            <Globe size={20} />
          </a>

   

        </div>

      </div>

    </div>

    <div class="mt-16 border-t border-zinc-800 pt-8">

      <div class="flex flex-col gap-5 md:flex-row md:items-center md:justify-between">

        <p class="text-sm text-zinc-500">
          © {year}
          <span class="font-semibold text-white">
            TRIMIT
          </span>
          . All rights reserved.
        </p>

        <div class="flex items-center gap-8 text-xs uppercase tracking-[0.3em] text-zinc-600">

          <span>FAST</span>

          <span>SECURE</span>

          <span>RELIABLE</span>

        </div>

      </div>

    </div>

  </div>

</footer>