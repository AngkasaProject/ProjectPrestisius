---
import "@/styles/global.css";

interface Props {
  title?: string;
}

const { title = "Angkasa Project" } = Astro.props;
---

<!doctype html>

<html lang="id">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-linear-to-br from-zinc-100 via-white to-zinc-100 text-zinc-900 antialiased">
    <slot />
  </body>
</html>