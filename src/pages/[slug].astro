---
import { supabase } from "@/lib/supabase/server";
import RedirectLayout from "@/layouts/RedirectLayout.astro";
import FlowPage from "@/components/flow/FlowPage";
import { isCrawler } from "@/lib/redirect/crawler";
import { resolveMetadata } from "@/lib/redirect/resolveMetadata";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/");
}

const requestUrl = Astro.request.url;
const cacheKey = new Request(requestUrl, Astro.request);
const cache = typeof caches !== 'undefined' ? (caches as CacheStorage & { default: Cache }).default : null;
const runtime = Astro.locals.runtime;

const userAgent = Astro.request.headers.get("user-agent") ?? "";
const crawler = isCrawler(userAgent);

if (!crawler && cache) {
  let cachedResponse = await cache.match(cacheKey);
  if (cachedResponse) {
    return cachedResponse;
  }
}

const { data: link } = await supabase
  .from("links")
  .select("*, profiles(status)")
  .eq("slug", slug)
  .single();

const isSuspended = (link?.profiles as any)?.status === 'suspended';

if (!link || !link.status || isSuspended) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

if (!crawler) {
  const updatePromise = (async () => {
    await supabase
      .from("links")
      .update({ clicks: (link.clicks ?? 0) + 1 })
      .eq("id", link.id);
  })();

  if (runtime?.ctx?.waitUntil) {
    runtime.ctx.waitUntil(updatePromise);
  } else {
    updatePromise.catch(() => {});
  }
}

if (!crawler && link.mode === "direct") {
  const directResponse = Astro.redirect(link.destination_url, 302);
  directResponse.headers.set('Cache-Control', 'public, max-age=3600');
  
  if (runtime?.ctx?.waitUntil && cache) {
    runtime.ctx.waitUntil(cache.put(cacheKey, directResponse.clone()));
  }
  
  return directResponse;
}

const hostname = new URL(link.destination_url).hostname;
const metadata = await resolveMetadata(link);
---

<RedirectLayout
  title={metadata.title}
  description={metadata.description}
  image={metadata.image ?? "/brand/logo-kotak.png"}
>
  <FlowPage
    client:load
    destination={link.destination_url}
    hostname={hostname}
    metadata={metadata}
  />
</RedirectLayout>