---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import AppShell from "@/components/layout/AppShell";
import AdminUserTable from "@/components/pages/AdminUserTable";
---

<DashboardLayout title="Global Stats - Admin Panel">
  <AppShell client:load>
    <div class="space-y-6">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-zinc-900">
          Admin Panel
        </h1>
        <p class="mt-1 text-sm text-zinc-500">
          Ikhtisar seluruh pengguna terdaftar dan jumlah tautan yang mereka kelola.
        </p>
      </div>

      <AdminUserTable client:load />
    </div>
  </AppShell>
</DashboardLayout>