---
import PublicLayout from "@/layouts/PublicLayout.astro";
import AuthBackground from "@/components/auth/AuthBackground.astro";
import RegisterForm from "@/components/auth/RegisterForm";
---

<PublicLayout title="Register">

  <main class="relative flex min-h-screen items-center justify-center overflow-hidden px-4 py-10">

    <AuthBackground />

    <div class="relative z-10 w-full max-w-md rounded-3xl border border-zinc-200/70 bg-white/80 p-10 shadow-2xl backdrop-blur-xl">

      <!-- Logo -->
      <div class="flex justify-center">
        <img
          src="/brand/logo-kotak.png"
          alt="TRIM IT"
          class="h-24 w-auto"
        />
      </div>

      <!-- Heading -->
      <h1 class="mt-8 text-center text-3xl font-bold">
        Create Account
      </h1>

      <p class="mt-3 text-center leading-6 text-zinc-500">
        Create your account to start managing your short links.
      </p>

      <RegisterForm client:load />

      <div class="mt-8 border-t border-zinc-200 pt-6 text-center text-sm text-zinc-500">
        Already have an account?

        <a
          href="/login"
          class="font-medium text-zinc-900 transition hover:underline"
        >
          Login
        </a>
      </div>

    </div>

  </main>

</PublicLayout>