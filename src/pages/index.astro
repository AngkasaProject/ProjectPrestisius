---
import PublicLayout from "@/layouts/PublicLayout.astro";
---

<PublicLayout title="Angkasa Project">
  <main class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-md rounded-3xl border border-zinc-200 bg-white p-10 text-center shadow-xl">
      <!-- Logo -->
      <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-3xl bg-zinc-900 text-2xl font-bold text-white">
        AP
      </div>

      <!-- Heading -->
      <h1 class="mt-8 text-3xl font-bold tracking-tight">
        Welcome to Angkasa Project
      </h1>

      <p class="mt-6 leading-7 text-zinc-500">
        Thank you for your interest in our website.
      </p>

      <p class="mt-3 leading-7 text-zinc-500">
        Unfortunately, our platform is not publicly available yet.
        We're currently preparing everything for launch and will
        open access to everyone soon.
      </p>

      <p class="mt-3 leading-7 text-zinc-500">
        If you already have an account, please sign in below.
      </p>

      <!-- Action -->
      <div class="mt-10 space-y-3">
        <a
          href="/login"
          class="flex h-12 items-center justify-center rounded-xl bg-zinc-900 font-medium text-white transition hover:bg-zinc-800"
        >
          Login
        </a>

        <a
          href="/register"
          class="flex h-12 items-center justify-center rounded-xl border border-zinc-200 font-medium text-zinc-700 transition hover:bg-zinc-100"
        >
          Register
        </a>
      </div>

      <!-- Footer -->
      <div class="mt-10 border-t border-zinc-200 pt-6">
        <p class="text-sm text-zinc-500">
          © 2026 Angkasa Project
        </p>
      </div>
    </div>
  </main>
</PublicLayout>